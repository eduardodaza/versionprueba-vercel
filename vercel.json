{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/transcribe.js": {
      "maxDuration": 60
    },
    "api/parse-transcription.js": {
      "maxDuration": 60
    },
    "api/edit-text.js": {
      "maxDuration": 60
    }
  }
}